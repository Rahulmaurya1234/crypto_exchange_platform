# ============================================
# CRYPTIANS P2P MARKETPLACE - ENVIRONMENT VARIABLES
# ============================================

# Application
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173
API_VERSION=v1

# Database - MongoDB (Development)
MONGO_URI=mongodb://localhost:27017
DBNAME=cryptians_dev

# Database - AWS DocumentDB (Production)
AWS_DOCUMENTDB_URI=
AWS_DOCUMENTDB_CA_CERT=
AWS_DOCUMENTDB_REPLICA_SET=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_ACCESS_TOKEN_EXPIRY=15m
REFRESH_JWT_SECRET=your-super-secret-refresh-jwt-key-change-this
REFRESH_TOKEN_EXPIRES_IN=30d
REFRESH_COOKIE_NAME=refresh_token
REFRESH_COOKIE_SECURE=false
REFRESH_COOKIE_SAME_SITE=lax

# AWS S3
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=cryptians-uploads
AWS_S3_KYC_BUCKET=cryptians-kyc-documents
AWS_S3_PAYMENT_PROOFS_BUCKET=cryptians-payment-proofs

# KYC Provider (ShuftiPro / Signzy / Sumsub)
KYC_PROVIDER=shufti
SHUFTI_CLIENT_ID=
SHUFTI_SECRET_KEY=
SHUFTI_WEBHOOK_SECRET=

# SMS Provider (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_VERIFY_SERVICE_SID=

# Email Provider (SendGrid)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@cryptians.com
SENDGRID_FROM_NAME=Cryptians

# SMTP Configuration (Nodemailer - Gmail, Outlook, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=Cryptians <your-email@gmail.com>
ADMIN_KYC_EMAIL=admin@cryptians.com

# OCR - Google Vision (Payment Proof Verification)
GOOGLE_VISION_API_KEY=
GOOGLE_APPLICATION_CREDENTIALS=

# Price Feed APIs
CHAINLINK_API_URL=
BINANCE_API_URL=https://api.binance.com/api/v3
COINGECKO_API_URL=https://api.coingecko.com/api/v3
PRICE_FEED_UPDATE_INTERVAL=60000

# Escrow Configuration
ESCROW_WALLET_ADDRESS=0x1234567890abcdef
ESCROW_HOT_WALLET_ADDRESS=
ESCROW_MULTI_SIG_ADDRESS=

# Fee Configuration (INR-based - Buyer pays)
PLATFORM_FEE_PERCENT=5.0
GAS_FEE_PERCENT=1.0

# Fee Configuration (Crypto-based - Seller deposits)
ESCROW_PLATFORM_FEE_PERCENT=4.0

# Legacy Fee Config (deprecated, will be removed)
ESCROW_GAS_BUFFER_PERCENT=0.30
ESCROW_VOLATILITY_BUFFER_PERCENT=0.20

# Blockchain RPC (Ethereum / Polygon / BSC)
BLOCKCHAIN_NETWORK=polygon
POLYGON_RPC_URL=https://polygon-rpc.com
ETHEREUM_RPC_URL=
BSC_RPC_URL=

# Webhook Services (Moralis / Alchemy)
MORALIS_API_KEY=
ALCHEMY_API_KEY=

# Platform B (Support & Escrow) - Inter-Platform Auth
PLATFORM_B_API_URL=http://localhost:5001
PLATFORM_B_API_KEY=
PLATFORM_B_WEBHOOK_SECRET=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Trade Configuration
TRADE_HOLD_TIME_MINUTES=30
TRADE_AUTO_CANCEL_MINUTES=60
DISPUTE_WINDOW_MINUTES=30
MIN_TRADE_AMOUNT_USDT=10
MAX_TRADE_AMOUNT_USDT=100000

# Instant Seller Configuration
INSTANT_SELLER_MIN_DEPOSIT_USDT=500
INSTANT_SELLER_MAX_DEPOSIT_USDT=5000

# BullMQ Queue Configuration
BULLMQ_REDIS_HOST=localhost
BULLMQ_REDIS_PORT=6379

# Logging
LOG_LEVEL=info
LOG_DIR=./logs

# Security
ENABLE_CORS=true
ENABLE_HELMET=true
ENABLE_RATE_LIMIT=true

# Admin Panel
ADMIN_EMAIL=admin@cryptians.com
ADMIN_PASSWORD=ChangeMeInProduction123!

# Monitoring (Optional)
SENTRY_DSN=
PROMETHEUS_PORT=9090

# Notification Configuration
ENABLE_PUSH_NOTIFICATIONS=true
FCM_SERVER_KEY=
FCM_PROJECT_ID=

# File Upload Limits
MAX_FILE_SIZE_MB=10
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf

# Session Configuration
SESSION_SECRET=your-session-secret-key
