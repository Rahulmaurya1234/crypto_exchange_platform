{
  "info": {
    "name": "Instant Seller API Tests",
    "description": "Complete API test collection for Instant Seller and Regular Seller flows",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "regularSellerToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "instantSellerToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "adminToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "listingId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. AUTHENTICATION",
      "item": [
        {
          "name": "Login - Regular Seller",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set('regularSellerToken', response.data.accessToken);",
                  "    pm.environment.set('regularSellerToken', response.data.accessToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"regular.seller@test.com\",\n  \"password\": \"Test@123456\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "login"]
            }
          }
        },
        {
          "name": "Login - Instant Seller",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set('instantSellerToken', response.data.accessToken);",
                  "    pm.environment.set('instantSellerToken', response.data.accessToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"instant.seller@test.com\",\n  \"password\": \"Test@123456\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "login"]
            }
          }
        },
        {
          "name": "Login - Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set('adminToken', response.data.accessToken);",
                  "    pm.environment.set('adminToken', response.data.accessToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@test.com\",\n  \"password\": \"Admin@123456\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "2. INSTANT SELLER FLOW",
      "item": [
        {
          "name": "Calculate Deposit Amount",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/platform-a/listings/instant-seller/calculate-deposit?amount=2000&network=ethereum",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "platform-a", "listings", "instant-seller", "calculate-deposit"],
              "query": [
                {
                  "key": "amount",
                  "value": "2000"
                },
                {
                  "key": "network",
                  "value": "ethereum"
                }
              ]
            }
          }
        },
        {
          "name": "Create Instant Seller Listing",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set('listingId', response.data.listing._id);",
                  "    pm.environment.set('listingId', response.data.listing._id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{instantSellerToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cryptoType\": \"USDT\",\n  \"availableAmount\": 2000,\n  \"pricePerUnit\": 91,\n  \"priceType\": \"fixed\",\n  \"minTradeLimit\": 100,\n  \"maxTradeLimit\": 2000,\n  \"paymentMethods\": [\"upi\", \"imps\"],\n  \"timeLimit\": 30,\n  \"terms\": \"Instant seller - crypto already in escrow\",\n  \"instructions\": \"Fast transaction guaranteed\",\n  \"transactionHash\": \"0x1234567890abcdef1234567890abcdef1234567890abcdef1234567890abcdef\",\n  \"totalDepositAmount\": 2086,\n  \"originalAmount\": 2000,\n  \"platformFeeUSDT\": 80,\n  \"gasFeeUSDT\": 6,\n  \"network\": \"ethereum\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/platform-a/listings/instant-seller",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "platform-a", "listings", "instant-seller"]
            }
          }
        },
        {
          "name": "Get My Deposits",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{instantSellerToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/platform-a/listings/instant-seller/deposits",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "platform-a", "listings", "instant-seller", "deposits"]
            }
          }
        },
        {
          "name": "Resubmit Rejected Listing",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{instantSellerToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"newTransactionHash\": \"0xfedcba0987654321fedcba0987654321fedcba0987654321fedcba0987654321\",\n  \"comments\": \"Corrected transaction hash\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/platform-a/listings/instant-seller/{{listingId}}/resubmit",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "platform-a", "listings", "instant-seller", "{{listingId}}", "resubmit"]
            }
          }
        }
      ]
    },
    {
      "name": "3. REGULAR SELLER FLOW",
      "item": [
        {
          "name": "Create Regular Listing",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{regularSellerToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cryptoType\": \"USDT\",\n  \"availableAmount\": 5000,\n  \"pricePerUnit\": 92,\n  \"priceType\": \"fixed\",\n  \"minTradeLimit\": 500,\n  \"maxTradeLimit\": 5000,\n  \"paymentMethods\": [\"upi\", \"imps\", \"bank_transfer\"],\n  \"timeLimit\": 30,\n  \"terms\": \"Payment must be made within 30 minutes\",\n  \"instructions\": \"Please complete payment to provided account\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/platform-a/listings",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "platform-a", "listings"]
            }
          }
        },
        {
          "name": "Get My Listings",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{regularSellerToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/platform-a/listings/my-listings",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "platform-a", "listings", "my-listings"]
            }
          }
        }
      ]
    },
    {
      "name": "4. ADMIN OPERATIONS",
      "item": [
        {
          "name": "Get Pending Deposits",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/platform-a/admin/listings/pending-deposits",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "platform-a", "admin", "listings", "pending-deposits"]
            }
          }
        },
        {
          "name": "Get Deposit Details",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/platform-a/admin/listings/{{listingId}}/deposit",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "platform-a", "admin", "listings", "{{listingId}}", "deposit"]
            }
          }
        },
        {
          "name": "Approve Deposit",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"verified\": true,\n  \"notes\": \"Transaction hash verified on blockchain\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/platform-a/admin/listings/{{listingId}}/approve-deposit",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "platform-a", "admin", "listings", "{{listingId}}", "approve-deposit"]
            }
          }
        },
        {
          "name": "Reject Deposit",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"verified\": false,\n  \"rejectionReason\": \"Transaction hash not found on blockchain\",\n  \"canResubmit\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/platform-a/admin/listings/{{listingId}}/approve-deposit",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "platform-a", "admin", "listings", "{{listingId}}", "approve-deposit"]
            }
          }
        }
      ]
    },
    {
      "name": "5. PUBLIC LISTING APIs",
      "item": [
        {
          "name": "Search All Listings",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/platform-a/listings?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "platform-a", "listings"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "20"
                }
              ]
            }
          }
        },
        {
          "name": "Search Instant Seller Listings",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/platform-a/listings?isInstantSeller=true",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "platform-a", "listings"],
              "query": [
                {
                  "key": "isInstantSeller",
                  "value": "true"
                }
              ]
            }
          }
        },
        {
          "name": "Search Regular Seller Listings",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/platform-a/listings?isInstantSeller=false",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "platform-a", "listings"],
              "query": [
                {
                  "key": "isInstantSeller",
                  "value": "false"
                }
              ]
            }
          }
        },
        {
          "name": "Get Listing by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/platform-a/listings/{{listingId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "platform-a", "listings", "{{listingId}}"]
            }
          }
        }
      ]
    }
  ]
}
